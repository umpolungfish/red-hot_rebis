<?xml version="1.0" encoding="UTF-8"?>
<sbml xmlns="http://www.sbml.org/sbml/level3/version2/core" level="3" version="2">
  <model id="detox_gland_angiogenesis" name="In-Situ Angiogenesis Model — Gland Vascularization">
    <notes>
      <body xmlns="http://www.w3.org/1999/xhtml">
        <p>Mathematical model of in-situ angiogenesis for the synthetic detox gland (v2.0).</p>
        <p>Models: growth factor diffusion → endothelial tip cell migration → sprout elongation → anastomosis → perfusion</p>
        <p>Governing PDE: ∂c/∂t = D∇²c - λc + S(x,t) for each growth factor, coupled to cellular response via stochastic tip cell migration.</p>
      </body>
    </notes>
    
    <listOfUnitDefinitions>
      <unitDefinition id="mmol">
        <listOfUnits><unit kind="mole" scale="-3"/></listOfUnits>
      </unitDefinition>
      <unitDefinition id="per_second">
        <listOfUnits><unit kind="second" exponent="-1"/></listOfUnits>
      </unitDefinition>
      <unitDefinition id="cm">
        <listOfUnits><unit kind="metre" scale="-2"/></listOfUnits>
      </unitDefinition>
      <unitDefinition id="cm2_per_second">
        <listOfUnits><unit kind="metre" scale="-2" exponent="2"/><unit kind="second" exponent="-1"/></listOfUnits>
      </unitDefinition>
    </listOfUnitDefinitions>

    <listOfCompartments>
      <compartment id="gel_scaffold" size="3e-6" constant="true" units="litre"/>
      <compartment id="host_tissue" size="1e-4" constant="true" units="litre"/>
      <compartment id="blood" size="5" constant="true" units="litre"/>
    </listOfCompartments>

    <listOfSpecies>
      <!-- Growth factors -->
      <species id="VEGF" compartment="gel_scaffold" initialConcentration="0.001" hasOnlySubstanceUnits="false" boundaryCondition="false"/>
      <species id="bFGF" compartment="gel_scaffold" initialConcentration="0.0005" hasOnlySubstanceUnits="false" boundaryCondition="false"/>
      <species id="Ang1" compartment="gel_scaffold" initialConcentration="0.002" hasOnlySubstanceUnits="false" boundaryCondition="false"/>
      <species id="SDF1a" compartment="gel_scaffold" initialConcentration="0.001" hasOnlySubstanceUnits="false" boundaryCondition="false"/>
      
      <!-- Host response -->
      <species id="VEGF_host" compartment="host_tissue" initialConcentration="0" hasOnlySubstanceUnits="false" boundaryCondition="false"/>
      <species id="tip_cells_activated" compartment="host_tissue" initialConcentration="0" hasOnlySubstanceUnits="false" boundaryCondition="false"/>
      <species id="sprout_length" compartment="host_tissue" initialConcentration="0" hasOnlySubstanceUnits="false" boundaryCondition="false"/>
      <species id="EPC_homed" compartment="gel_scaffold" initialConcentration="0" hasOnlySubstanceUnits="false" boundaryCondition="false"/>
      
      <!-- Gland vascular status -->
      <species id="perfused_volume_fraction" compartment="gel_scaffold" initialConcentration="0" hasOnlySubstanceUnits="false" boundaryCondition="false"/>
      <species id="vessel_density" compartment="gel_scaffold" initialConcentration="0" hasOnlySubstanceUnits="false" boundaryCondition="false"/>
      
      <!-- Antidute secretion (earliest functional signal) -->
      <species id="antidote_blood" compartment="blood" initialConcentration="0" hasOnlySubstanceUnits="false" boundaryCondition="false"/>
      <species id="hypoxia_signal" compartment="gel_scaffold" initialConcentration="1" hasOnlySubstanceUnits="false" boundaryCondition="false"/>
    </listOfSpecies>

    <listOfParameters>
      <!-- Diffusion constants [cm²/s] -->
      <parameter id="D_VEGF" value="1.5e-7" units="cm2_per_second"/>
      <parameter id="D_bFGF" value="1.0e-7" units="cm2_per_second"/>
      <parameter id="D_SDF1" value="2.0e-7" units="cm2_per_second"/>
      
      <!-- Decay rates [per_second] -->
      <parameter id="lambda_VEGF" value="2.0e-5" units="per_second"/>
      <parameter id="lambda_bFGF" value="1.0e-5" units="per_second"/>
      
      <!-- Angiogenesis parameters -->
      <parameter id="k_tip_activation" value="5.0e-4" units="per_second"/>
      <parameter id="k_sprout_elongation" value="1.0e-4" units="cm_per_second"/>
      <parameter id="k_EPC_homing" value="2.0e-5" units="per_second"/>
      <parameter id="k_anastomosis" value="1.0e-6" units="per_second"/>
      <parameter id="K_VEGF_half" value="0.0005" units="mmol"/>
      
      <!-- Secretion -->
      <parameter id="k_antidote_secretion" value="1.0e-8" units="per_second"/>
      <parameter id="k_hypoxia_decay" value="5.0e-6" units="per_second"/>
      <parameter id="vessel_perfusion_rate" value="0.1" units="per_second"/>
    </listOfParameters>

    <listOfReactions>
      <!-- GF diffusion approximation (0D spatial lumped) -->
      <reaction id="VEGF_release_from_gel" reversible="false">
        <listOfReactants/>
        <listOfProducts>
          <speciesReference species="VEGF" stoichiometry="1"/>
        </listOfProducts>
        <kineticLaw>
          <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
              <times/>
              <cn> 0.001 </cn>
              <apply>
                <exp/>
                <apply>
                  <times/>
                  <cn> -0.0005 </cn>
                  <ci> time </ci>
                </apply>
              </apply>
            </apply>
          </math>
        </kineticLaw>
      </reaction>

      <reaction id="VEGF_diffusion_to_host" reversible="false">
        <listOfReactants>
          <speciesReference species="VEGF" stoichiometry="1"/>
        </listOfReactants>
        <listOfProducts>
          <speciesReference species="VEGF_host" stoichiometry="1"/>
        </listOfProducts>
        <kineticLaw>
          <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
              <times/>
              <ci> D_VEGF </ci>
              <ci> VEGF </ci>
            </apply>
          </math>
        </kineticLaw>
      </reaction>

      <reaction id="tip_cell_activation" reversible="false">
        <listOfReactants>
          <speciesReference species="VEGF_host" stoichiometry="1"/>
        </listOfReactants>
        <listOfProducts>
          <speciesReference species="tip_cells_activated" stoichiometry="1"/>
        </listOfProducts>
        <kineticLaw>
          <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
              <times/>
              <ci> k_tip_activation </ci>
              <apply>
                <divide/>
                <ci> VEGF_host </ci>
                <apply>
                  <plus/>
                  <ci> K_VEGF_half </ci>
                  <ci> VEGF_host </ci>
                </apply>
              </apply>
            </apply>
          </math>
        </kineticLaw>
      </reaction>

      <reaction id="sprout_elongation" reversible="false">
        <listOfReactants>
          <speciesReference species="tip_cells_activated" stoichiometry="1"/>
          <speciesReference species="VEGF" stoichiometry="1"/>
        </listOfReactants>
        <listOfProducts>
          <speciesReference species="sprout_length" stoichiometry="1"/>
        </listOfProducts>
        <kineticLaw>
          <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
              <times/>
              <ci> k_sprout_elongation </ci>
              <ci> VEGF </ci>
              <ci> tip_cells_activated </ci>
            </apply>
          </math>
        </kineticLaw>
      </reaction>

      <reaction id="EPC_homing_SDF1" reversible="false">
        <listOfReactants>
          <speciesReference species="SDF1a" stoichiometry="1"/>
        </listOfReactants>
        <listOfProducts>
          <speciesReference species="EPC_homed" stoichiometry="1"/>
        </listOfProducts>
        <kineticLaw>
          <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
              <times/>
              <ci> k_EPC_homing </ci>
              <ci> SDF1a </ci>
            </apply>
          </math>
        </kineticLaw>
      </reaction>

      <reaction id="vessel_formation_anastomosis" reversible="false">
        <listOfReactants>
          <speciesReference species="sprout_length" stoichiometry="1"/>
          <speciesReference species="EPC_homed" stoichiometry="1"/>
        </listOfReactants>
        <listOfProducts>
          <speciesReference species="vessel_density" stoichiometry="1"/>
        </listOfProducts>
        <kineticLaw>
          <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
              <times/>
              <ci> k_anastomosis </ci>
              <ci> sprout_length </ci>
              <ci> EPC_homed </ci>
            </apply>
          </math>
        </kineticLaw>
      </reaction>

      <reaction id="perfusion_development" reversible="false">
        <listOfReactants>
          <speciesReference species="vessel_density" stoichiometry="1"/>
        </listOfReactants>
        <listOfProducts>
          <speciesReference species="perfused_volume_fraction" stoichiometry="1"/>
        </listOfProducts>
        <kineticLaw>
          <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
              <times/>
              <ci> vessel_perfusion_rate </ci>
              <ci> vessel_density </ci>
              <apply>
                <minus/>
                <cn> 1 </cn>
                <ci> perfused_volume_fraction </ci>
              </apply>
            </apply>
          </math>
        </kineticLaw>
      </reaction>

      <reaction id="antidote_secretion" reversible="false">
        <listOfReactants>
          <speciesReference species="perfused_volume_fraction" stoichiometry="1"/>
          <speciesReference species="hypoxia_signal" stoichiometry="1"/>
        </listOfReactants>
        <listOfProducts>
          <speciesReference species="antidote_blood" stoichiometry="1"/>
        </listOfProducts>
        <kineticLaw>
          <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
              <times/>
              <ci> k_antidote_secretion </ci>
              <ci> perfused_volume_fraction </ci>
              <ci> hypoxia_signal </ci>
            </apply>
          </math>
        </kineticLaw>
      </reaction>

      <reaction id="hypoxia_resolution" reversible="false">
        <listOfReactants>
          <speciesReference species="hypoxia_signal" stoichiometry="1"/>
          <speciesReference species="perfused_volume_fraction" stoichiometry="1"/>
        </listOfReactants>
        <kineticLaw>
          <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
              <times/>
              <ci> k_hypoxia_decay </ci>
              <ci> hypoxia_signal </ci>
              <apply>
                <power/>
                <ci> perfused_volume_fraction </ci>
                <cn> 2 </cn>
              </apply>
            </apply>
          </math>
        </kineticLaw>
      </reaction>
    </listOfReactions>
  </model>
</sbml>
