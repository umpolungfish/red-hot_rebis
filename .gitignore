# Red-Hot Rebis — .gitignore

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# venv
.venv/
venv/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs
*.log

# LaTeX intermediates
*.aux
*.out
*.toc
*.fls
*.fdb_latexmk
*.synctex.gz

# Backup files — never commit these
*.bak
*.p4rakernel_backup
*.zip
*.json.bak

# pytest
.pytest_cache/

# Stray junk
_write_test.txt

# External reference PDFs kept on disk, not in git (patents, etc.)
_archive/*.pdf
